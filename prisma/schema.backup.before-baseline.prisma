generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String       @id @default(uuid())
  email             String       @unique
  password          String
  role              Role         @default(CLIENT)

  companyName       String?
  nip               String?
  address           String?
  contactPerson     String?
  phone             String?

  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  orders            Order[]

  termsAccepted     Boolean      @default(false)
  termsAcceptedAt   DateTime?
  marketingConsent  Boolean      @default(false)

  createdNotes      OrderNote[]  @relation("OrderNoteAuthor")
  createdEvents     OrderEvent[] @relation("OrderEventAuthor")
}

enum Role {
  CLIENT
  ADMIN
}

model ExamTemplate {
  id               String     @id @default(uuid())
  title            String
  description      String
  isCustom         Boolean    @default(false)

  learningOutcomes String?    @db.Text
  level            String?

  createdAt        DateTime   @default(now())
  orders           Order[]
  questions        Question[]
}

model Question {
  id             String       @id @default(uuid())
  examTemplateId String
  examTemplate   ExamTemplate @relation(fields: [examTemplateId], references: [id], onDelete: Cascade)
  content        String
  options        String[]
  correctAnswer  Int
  createdAt      DateTime     @default(now())
}

model Order {
  id                 String        @id @default(uuid())
  clientId           String
  client             User          @relation(fields: [clientId], references: [id])
  examTemplateId     String?
  examTemplate       ExamTemplate? @relation(fields: [examTemplateId], references: [id])
  status             OrderStatus   @default(NEW)
  invoiceUrl         String?
  trainingProgramUrl String?
  generatedTestUrl   String?
  scannedAnswersUrl  String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  participants       Participant[]
  documents          Document[]
  notes              OrderNote[]
  events             OrderEvent[]
}

enum OrderStatus {
  NEW
  CONFIRMED
  TEST_READY
  SCANS_UPLOADED
  COMPLETED
}

model Participant {
  id             String   @id @default(uuid())
  orderId        String
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  firstName      String
  lastName       String
  birthDate      String
  birthPlace     String
  certificateUrl String?
  score          Int?
  maxScore       Int?
  testFinished   Boolean  @default(false)
  scannedTestUrl String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Document {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fileName  String
  fileUrl   String
  fileType  String
  createdAt DateTime @default(now())
}

model OrderNote {
  id           String    @id @default(uuid())
  orderId       String
  order         Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  authorUserId  String?
  authorUser    User?     @relation("OrderNoteAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)

  authorEmail   String?
  authorRole    Role?
  content       String    @db.Text
  isPinned      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([orderId, createdAt])
}

model OrderEvent {
  id            String         @id @default(uuid())
  orderId        String
  order          Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)

  actorUserId    String?
  actorUser      User?          @relation("OrderEventAuthor", fields: [actorUserId], references: [id], onDelete: SetNull)

  actorEmail     String?
  actorRole      Role?
  type           OrderEventType
  title          String
  description    String         @db.Text
  metadata       Json?
  createdAt      DateTime       @default(now())

  @@index([orderId, createdAt])
  @@index([type, createdAt])
}

enum OrderEventType {
  ORDER_CREATED
  STATUS_CHANGED
  INVOICE_UPDATED
  TEST_UPDATED
  DOCUMENT_UPLOADED
  PARTICIPANT_ADDED
  PARTICIPANT_REMOVED
  NOTE_ADDED
  ORDER_DELETED
  SYSTEM_INFO
}